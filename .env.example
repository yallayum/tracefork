# Gemini API (Phase 2)
GEMINI_API_KEY=

# Firebase — use emulator by default for local dev
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
GOOGLE_CLOUD_PROJECT=tracefork-3f5ac

# Set USE_FIRESTORE_EMULATOR=false to connect to production Firestore
USE_FIRESTORE_EMULATOR=true

# Optional: path to service account JSON for production seed/read
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
